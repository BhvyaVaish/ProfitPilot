# ─────────────────────────────────────────────────────────────────────────────
#  ProfitPilot — Environment Variables Template
#  Copy this file to .env for local development (it is git-ignored).
#  For production on Vercel, add these in: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Get this from: Supabase → Project Settings → Database → Connection String (URI)
# Leave empty for local development (SQLite is used automatically)
DATABASE_URL=

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Base64-encode your service account JSON and paste here (for Vercel/production).
# For local dev, place firebase-service-account.json in the backend/ folder instead.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Firebase Client Config (served to frontend via /api/config) ───────────────
# Get these from: Firebase Console → Project Settings → General → Your Apps → Web App
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ── Google API Key (Gemini AI + Calendar) ─────────────────────────────────────
# Get a key at: https://console.cloud.google.com/ → Credentials → API Key
# Enable "Google Calendar API" and "Generative Language API" in your GCP project.
GOOGLE_API_KEY=
GOOGLE_CALENDAR_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────
# The full URL of your Vercel frontend (used for CORS in production)
FRONTEND_URL=https://profitpilotio.vercel.app
