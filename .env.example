# ─────────────────────────────────────────────────────────────────────────────
#  ProfitPilot — Environment Variables Template
#  Copy this file to .env for local development (it is git-ignored).
#  For production on Vercel, add these in: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Get this from: Supabase → Project Settings → Database → Connection String (URI)
# Use the "URI" format starting with postgresql://
# Leave empty for local development (SQLite is used automatically)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# OPTION A (Vercel/Production): Base64-encode your service account JSON and paste here.
#   How to encode:  python -c "import base64; print(base64.b64encode(open('backend/firebase-service-account.json','rb').read()).decode())"
# OPTION B (Local dev): Just place firebase-service-account.json in the backend/ folder.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Google API Key (Calendar + Gemini AI) ─────────────────────────────────
# Used for: 1) Google Calendar API (real-time festival data)
#            2) Gemini Generative AI (smart demand prediction)
# Get a free key at: https://console.cloud.google.com/ → Credentials → API Key
# Enable both "Google Calendar API" and "Generative Language API" in your project.
GOOGLE_API_KEY=YOUR_KEY_HERE
