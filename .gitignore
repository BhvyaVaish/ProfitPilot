# ── Python virtual environments ────────────────────────────────────────────
.venv/
.venv-*/
env/
venv/
ENV/

# ── Python bytecode & caches ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Environment variables & secrets ────────────────────────────────────────
# NEVER commit .env or files containing API keys / credentials
.env
.env.local
.env.production
frontend/js/firebase-config.js

# ── Database files ─────────────────────────────────────────────────────────
# Local SQLite DB — not used in production (Supabase replaces it)
*.db
*.sqlite

# ── Firebase service account ───────────────────────────────────────────────
# NEVER commit these — use FIREBASE_SERVICE_ACCOUNT_JSON env var on Vercel
backend/firebase-service-account.json
*firebase-adminsdk*
*serviceAccountKey*

# ── IDE & OS files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Temporary / Debug artifacts ────────────────────────────────────────────
archive/
emoji_out.txt
svgs.txt
*.log

# ── Vercel build output ────────────────────────────────────────────────────
.vercel/
