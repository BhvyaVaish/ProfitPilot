{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    
    { "src": "/(index|index\\.html)", "dest": "frontend/index.html" },
    { "src": "/(dashboard|dashboard\\.html)", "dest": "frontend/dashboard.html" },
    { "src": "/(inventory|inventory\\.html)", "dest": "frontend/inventory.html" },
    { "src": "/(billing|billing\\.html)", "dest": "frontend/billing.html" },
    { "src": "/(tax|tax\\.html)", "dest": "frontend/tax.html" },
    { "src": "/(chatbot|chatbot\\.html)", "dest": "frontend/chatbot.html" },
    { "src": "/(about|about\\.html)", "dest": "frontend/about.html" },
    { "src": "/(auth|auth\\.html)", "dest": "frontend/auth.html" },
    { "src": "/(onboarding|onboarding\\.html)", "dest": "frontend/onboarding.html" },
    { "src": "/(profile|profile\\.html)", "dest": "frontend/profile.html" },

    { "src": "/css/(.*)", "dest": "frontend/css/$1" },
    { "src": "/js/(.*)", "dest": "frontend/js/$1" },
    { "src": "/img/(.*)", "dest": "frontend/img/$1" },
    { "src": "/manifest.json", "dest": "frontend/manifest.json" },
    { "src": "/sw.js", "dest": "frontend/sw.js" },
    { "src": "/favicon.png", "dest": "frontend/favicon.png" },
    
    { "src": "/(.*)", "dest": "frontend/$1" },
    
    { "src": "/", "dest": "frontend/index.html" }
  ]
}
