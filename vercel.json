{
  "version": 2,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/js/(.*)", "dest": "frontend/js/$1" },
    { "src": "/css/(.*)", "dest": "frontend/css/$1" },
    { "src": "/img/(.*)", "dest": "frontend/img/$1" },
    { "src": "/manifest\\.json", "dest": "frontend/manifest.json" },
    { "src": "/sw\\.js", "dest": "frontend/sw.js" },
    { "src": "/favicon\\.png", "dest": "frontend/favicon.png" },
    { "src": "/(index|dashboard|inventory|billing|tax|chatbot|about|auth|onboarding|profile)\\.html$", "dest": "frontend/$1.html" },
    { "src": "/(index|dashboard|inventory|billing|tax|chatbot|about|auth|onboarding|profile)$", "dest": "frontend/$1.html" },
    { "src": "^/$", "dest": "frontend/index.html" }
  ]
}
