{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/auth",
      "dest": "frontend/auth.html"
    },
    {
      "src": "/onboarding",
      "dest": "frontend/onboarding.html"
    },
    {
      "src": "/profile",
      "dest": "frontend/profile.html"
    },
    {
      "src": "/dashboard",
      "dest": "frontend/dashboard.html"
    },
    {
      "src": "/inventory",
      "dest": "frontend/inventory.html"
    },
    {
      "src": "/billing",
      "dest": "frontend/billing.html"
    },
    {
      "src": "/tax",
      "dest": "frontend/tax.html"
    },
    {
      "src": "/chatbot",
      "dest": "frontend/chatbot.html"
    },
    {
      "src": "/about",
      "dest": "frontend/about.html"
    },
    {
      "src": "/manifest.json",
      "dest": "frontend/manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "frontend/sw.js"
    },
    {
      "src": "/favicon.png",
      "dest": "frontend/favicon.png"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/js/$1"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    }
  ]
}
