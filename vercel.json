{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/css/(.*)", "destination": "/frontend/css/$1" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" },
    { "source": "/img/(.*)", "destination": "/frontend/img/$1" },
    { "source": "/(manifest\\.json|sw\\.js|favicon\\.png)", "destination": "/frontend/$1" },
    { "source": "/(index|dashboard|inventory|billing|tax|chatbot|about|auth|onboarding|profile)", "destination": "/frontend/$1.html" },
    { "source": "/(.*)\\.html", "destination": "/frontend/$1.html" },
    { "source": "/", "destination": "/frontend/index.html" }
  ]
}
